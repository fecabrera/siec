import std.io;
import { Decimal } from std.decimal;

fn main(args: const char*[]) -> i32 {
    if (args.length != 3) {
		std.io.println(std.io.stderr, "sub: usage: {} x y", args[0]);
		return 1;
	}

    let a = Decimal(args[1]);
    defer a.destroy();

    let b = Decimal(args[2]);
    defer b.destroy();

    let result = a - b;
    defer result.destroy();

    let str = result.to_string();
    defer str.destroy();
    
    std.io.println("{}", str);

    return 0;
}