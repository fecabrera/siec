import std.io;
import { Decimal } from std.decimal;

fn main(args: const char*[]) -> i32 {
    if (args.length != 2) {
		std.io.println(std.io.stderr, "sqrt: usage: {} x", args[0]);
		return 1;
	}

    let dec = Decimal(args[1]);
    defer dec.destroy();

    let result = dec.sqrt();
    defer result.destroy();

    let str = result.to_string();
    defer str.destroy();
    
    std.io.println("{}", str);

    return 0;
}