import std.io;
import { stderr } from stdio;
import {
    mpd_init,
    mpd_new,
    mpd_del,
    mpd_set_string,
    mpd_div,
    mpd_to_sci,
    mpd_free,
    mpd_context,
} from mpdecimal;

fn main(args: char*[]) -> i32 {
    if (args.length != 3) {
		std.io.println(stderr, "div: usage: {} x y", args[0]);
		return 1;
	}

    let ctx: mpd_context;
    mpd_init(&ctx, 28);

    let a = mpd_new(&ctx);
    defer mpd_del(a);
    
    let b = mpd_new(&ctx);
    defer mpd_del(b);

    let result = mpd_new(&ctx);
    defer mpd_del(result);
    
    mpd_set_string(a, args[1], &ctx);
    mpd_set_string(b, args[2], &ctx);

    mpd_div(result, a, b, &ctx);

    let s = mpd_to_sci(result, 0);
    defer mpd_free(s);

    std.io.println("{}", s);

    return 0;
}