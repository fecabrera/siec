@extern fn mpd_qcopy_sign(result: mpd*, a: mpd*, b: mpd*, status: mpd_status*) -> i32;

@extern fn mpd_qand(result: mpd*, a: mpd*, b: mpd*, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qinvert(result: mpd*, a: mpd*, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qlogb(result: mpd*, a: mpd*, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qor(result: mpd*, a: mpd*, b: mpd*, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qscaleb(result: mpd*, a: mpd*, b: mpd*, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qxor(result: mpd*, a: mpd*, b: mpd*, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_same_quantum(a: mpd*, b: mpd*) -> i32;

@extern fn mpd_qrotate(result: mpd*, a: mpd*, b: mpd*, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qshiftl(result: mpd*, a: mpd*, n: i64, status: mpd_status*) -> i32;
@extern fn mpd_qshiftr(result: mpd*, a: mpd*, n: i64, status: mpd_status*) -> u64;
@extern fn mpd_qshiftr_inplace(result: mpd*, n: i64) -> u64;
