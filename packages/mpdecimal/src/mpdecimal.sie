import stdio;

/******************************************************************************/
/*                                  Version                                   */
/******************************************************************************/

@const MPD_MAJOR_VERSION = 4;
@const MPD_MINOR_VERSION = 0;
@const MPD_MICRO_VERSION = 1;

@const MPD_VERSION = "4.0.1";

@const MPD_VERSION_HEX = (MPD_MAJOR_VERSION << 24)
                         | (MPD_MINOR_VERSION << 16)
                         | (MPD_MICRO_VERSION <<  8);

@extern fn mpd_version() -> const char*;


/******************************************************************************/
/*                              Configuration                                 */
/******************************************************************************/

@const MPD_CONFIG_64 = 1;

@const MPD_UINT_MAX         = 0xFFFFFFFFFFFFFFFF;
@const MPD_BITS_PER_UINT    = 64;
@const MPD_RADIX            = 10000000000000000000;
@const MPD_RDIGITS          = 19;
@const MPD_MAX_POW10        = 19;
@const MPD_EXPDIGITS        = 19;
@const MPD_MAXTRANSFORM_2N  = 4294967296;
@const MPD_MAX_PREC         = 999999999999999999;
@const MPD_MAX_PREC_LOG2    = 64;
@const MPD_ELIMIT           = 1000000000000000000;
@const MPD_MAX_EMAX         = 999999999999999999;
@const MPD_MIN_EMIN         = -999999999999999999;
@const MPD_MIN_ETINY        = MPD_MIN_EMIN - (MPD_MAX_PREC - 1);
@const MPD_EXP_INF          = 2000000000000000001;
@const MPD_EXP_CLAMP        = -4000000000000000001;
@const MPD_MAXIMPORT        = 105263157894736842;
@const MPD_IEEE_CONTEXT_MAX_BITS = 512;

@const MPD_MINALLOC_MIN     = 2;
@const MPD_MINALLOC_MAX     = 64;

@const MPD_NUM_FLAGS        = 15;
@const MPD_MAX_FLAG_STRING  = 208;
@const MPD_MAX_FLAG_LIST    = MPD_MAX_FLAG_STRING + 18;
@const MPD_MAX_SIGNAL_LIST  = 121;


/******************************************************************************/
/*                                Context                                     */
/******************************************************************************/

enum mpd_round: i32 {
    UP              = 0,    /* round away from 0               */
    DOWN            = 1,    /* round toward 0 (truncate)       */
    CEILING         = 2,    /* round toward +infinity          */
    FLOOR           = 3,    /* round toward -infinity          */
    HALF_UP         = 4,    /* 0.5 is rounded up               */
    HALF_DOWN       = 5,    /* 0.5 is rounded down             */
    HALF_EVEN       = 6,    /* 0.5 is rounded to even          */
    ZERO_FIVE_UP    = 7,    /* round zero or five away from 0  */
    TRUNC           = 8,    /* truncate, but set infinity      */
    GUARD           = 9,
}

enum mpd_clamp: i32 {
    DEFAULT         = 0,
    IEEE_754        = 1,
    GUARD           = 2,
}

@extern let mpd_round_string: const @raw<char*>[mpd_round::GUARD];
@extern let mpd_clamp_string: const @raw<char*>[mpd_clamp::GUARD];

enum mpd_status: u32 {
    Clamped             = 0x00000001,
    Conversion_syntax   = 0x00000002,
    Division_by_zero    = 0x00000004,
    Division_impossible = 0x00000008,
    Division_undefined  = 0x00000010,
    Fpu_error           = 0x00000020,
    Inexact             = 0x00000040,
    Invalid_context     = 0x00000080,
    Invalid_operation   = 0x00000100,
    Malloc_error        = 0x00000200,
    Not_implemented     = 0x00000400,
    Overflow            = 0x00000800,
    Rounded             = 0x00001000,
    Subnormal           = 0x00002000,
    Underflow           = 0x00004000,
    Max_status          = 0x00008000 - 1,
}

@const MPD_IEEE_Invalid_operation = 0x000003BE;
@const MPD_Errors                 = 0x000003C6;
@const MPD_Traps                  = 0x00000C06;
@const MPD_Insufficient_storage   = 0x00000200;

struct mpd_context {
    prec:       i64;      /* precision */
    emax:       i64;      /* max positive exp */
    emin:       i64;      /* min negative exp */
    traps:      u32;     /* status events that should be trapped */
    status:     mpd_status; /* status flags */
    newtrap:    u32;     /* set by mpd_addstatus_raise() */
    round:      mpd_round;  /* rounding mode */
    clamp:      mpd_clamp;  /* clamp mode */
    allcr:      i32;      /* all functions correctly rounded */
}

enum mpd_decimal_size: i32 {
    DECIMAL32   = 32,
    DECIMAL64   = 64,
    DECIMAL128  = 128,
}

@extern let MPD_MINALLOC: i64;
@extern let mpd_traphandler: fn(mpd_context*);

@extern fn mpd_dflt_traphandler(ctx: mpd_context*);
@extern fn mpd_setminalloc(n: i64);
@extern fn mpd_init(ctx: mpd_context*, prec: i64);
@extern fn mpd_maxcontext(ctx: mpd_context*);
@extern fn mpd_defaultcontext(ctx: mpd_context*);
@extern fn mpd_basiccontext(ctx: mpd_context*);
@extern fn mpd_ieee_context(ctx: mpd_context*, bits: i32) -> i32;

@extern fn mpd_getprec(ctx: mpd_context*) -> i64;
@extern fn mpd_getemax(ctx: mpd_context*) -> i64;
@extern fn mpd_getemin(ctx: mpd_context*) -> i64;
@extern fn mpd_getround(ctx: mpd_context*) -> i32;
@extern fn mpd_gettraps(ctx: mpd_context*) -> u32;
@extern fn mpd_getstatus(ctx: mpd_context*) -> u32;
@extern fn mpd_getclamp(ctx: mpd_context*) -> i32;
@extern fn mpd_getcr(ctx: mpd_context*) -> i32;

@extern fn mpd_qsetprec(ctx: mpd_context*, prec: i64) -> i32;
@extern fn mpd_qsetemax(ctx: mpd_context*, emax: i64) -> i32;
@extern fn mpd_qsetemin(ctx: mpd_context*, emin: i64) -> i32;
@extern fn mpd_qsetround(ctx: mpd_context*, newround: i32) -> i32;
@extern fn mpd_qsettraps(ctx: mpd_context*, flags: u32) -> i32;
@extern fn mpd_qsetstatus(ctx: mpd_context*, flags: u32) -> i32;
@extern fn mpd_qsetclamp(ctx: mpd_context*, c: i32) -> i32;
@extern fn mpd_qsetcr(ctx: mpd_context*, c: i32) -> i32;
@extern fn mpd_addstatus_raise(ctx: mpd_context*, flags: u32);


/******************************************************************************/
/*                           Decimal Arithmetic                               */
/******************************************************************************/

enum mpd_flags: u8 {
    POS         = 0,
    NEG         = 1,
    INF         = 2,
    NAN         = 4,
    SNAN        = 8,
    SPECIAL     = mpd_flags::INF | mpd_flags::NAN | mpd_flags::SNAN,
    STATIC      = 16,
    STATIC_DATA = 32,
    SHARED_DATA = 64,
    CONST_DATA  = 128,
    DATAFLAGS   = mpd_flags::STATIC_DATA | mpd_flags::SHARED_DATA | mpd_flags::CONST_DATA,
}

struct mpd {
    flags:      mpd_flags;
    exp:        i64;
    digits:     i64;
    length:     i64;
    alloc:      i64;
    data:       u64*;
}


/******************************************************************************/
/*                                    Triple                                  */
/******************************************************************************/

enum mpd_triple_class: u8 {
    NORMAL  = 0,
    INF     = 1,
    QNAN    = 2,
    SNAN    = 3,
    ERROR   = 4,
}

struct mpd_uint128_triple {
    tag:      mpd_triple_class;
    sign:     u8;
    hi:       u64;
    lo:       u64;
    exp:      i64;
}

@extern fn mpd_from_uint128_triple(result: mpd*, triple: mpd_uint128_triple*, status: mpd_status*) -> i32;
@extern fn mpd_as_uint128_triple(a: mpd*) -> mpd_uint128_triple;


/******************************************************************************/
/*                       Quiet, thread-safe functions                         */
/******************************************************************************/

struct mpd_spec {
    min_width:      i64;            /* minimum field width */
    prec:           i64;            /* fraction digits or significant digits */
    type:           char;           /* conversion specifier */
    align:          char;           /* alignment */
    sign:           char;           /* sign printing/alignment */
    sign_coerce:    char;           /* coerce to positive zero */
    fill:           char[5];        /* fill character */
    dot:            const char*;    /* decimal point */
    sep:            const char*;    /* thousands separator */
    grouping:       const char*;    /* grouping of digits */
}

@extern fn mpd_to_sci(dec: mpd*, fmt: i32) -> char*;
@extern fn mpd_to_eng(dec: mpd*, fmt: i32) -> char*;
@extern fn mpd_to_sci_size(res: char**, dec: mpd*, fmt: i32) -> i64;
@extern fn mpd_to_eng_size(res: char**, dec: mpd*, fmt: i32) -> i64;
@extern fn mpd_validate_lconv(spec: mpd_spec*) -> i32;
@extern fn mpd_parse_fmt_str(spec: mpd_spec*, fmt: char*, caps: i32) -> i32;
@extern fn mpd_qformat_spec(dec: mpd*, spec: mpd_spec*, ctx: mpd_context*, status: mpd_status*) -> char*;
@extern fn mpd_qformat(dec: mpd*, fmt: char*, ctx: mpd_context*, status: mpd_status*) -> char*;

@extern fn mpd_snprint_flags(dest: char*, nmemb: i32, flags: u32) -> i32;
@extern fn mpd_lsnprint_flags(dest: char*, nmemb: i32, flags: u32, flag_string: const char**) -> i32;
@extern fn mpd_lsnprint_signals(dest: char*, nmemb: i32, flags: u32, signal_string: const char**) -> i32;

@extern fn mpd_fprint(file: FILE*, dec: mpd*);
@extern fn mpd_print(dec: mpd*);

/* assignment from a string */
@extern fn mpd_qset_string(dec: mpd*, s: char*, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qset_string_exact(dec: mpd*, s: char*, status: mpd_status*);

/* set to NaN with error flags */
@extern fn mpd_seterror(result: mpd*, flags: u32, status: mpd_status*);
/* set a special with sign and type */
@extern fn mpd_setspecial(result: mpd*, sign: u8, type: u8);
/* set coefficient to zero or all nines */
@extern fn mpd_zerocoeff(result: mpd*);
@extern fn mpd_qmaxcoeff(result: mpd*, ctx: mpd_context*, status: mpd_status*);

/* quietly assign a C integer type to an mpd_t */
@extern fn mpd_qset_ssize(result: mpd*, a: i64, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qset_i32(result: mpd*, a: i32, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qset_uint(result: mpd*, a: u64, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qset_u32(result: mpd*, a: u32, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qset_i64(result: mpd*, a: i64, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qset_u64(result: mpd*, a: u64, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qset_i64_exact(result: mpd*, a: i64, status: mpd_status*);
@extern fn mpd_qset_u64_exact(result: mpd*, a: u64, status: mpd_status*);

/* quietly assign a C integer type to an mpd_t with a static coefficient */
@extern fn mpd_qsset_ssize(result: mpd*, a: i64, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qsset_i32(result: mpd*, a: i32, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qsset_uint(result: mpd*, a: u64, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qsset_u32(result: mpd*, a: u32, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qsset_i64(result: mpd*, a: i64, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qsset_u64(result: mpd*, a: u64, ctx: mpd_context*, status: mpd_status*);
@extern fn mpd_qsset_i64_exact(result: mpd*, a: i64, status: mpd_status*);
@extern fn mpd_qsset_u64_exact(result: mpd*, a: u64, status: mpd_status*);

/* quietly get a C integer type from an mpd_t */
@extern fn mpd_qget_ssize(dec: mpd*, status: mpd_status*) -> i64;
@extern fn mpd_qget_i32(dec: mpd*, status: mpd_status*) -> i32;
@extern fn mpd_qget_uint(dec: mpd*, status: mpd_status*) -> u64;
@extern fn mpd_qget_u32(dec: mpd*, status: mpd_status*) -> u32;
@extern fn mpd_qget_i64(dec: mpd*, status: mpd_status*) -> i64;
@extern fn mpd_qget_u64(dec: mpd*, status: mpd_status*) -> u64;
@extern fn mpd_qabs_uint(dec: mpd*, status: mpd_status*) -> u64;

/* quiet functions */
@extern fn mpd_qcheck_nan(nanresult: mpd*, a: mpd*, ctx: mpd_context*, status: mpd_status*) -> i32;
@extern fn mpd_qcheck_nans(nansresult: mpd*, a: mpd*, b: mpd*, ctx: mpd_context*, status: mpd_status*) -> i32;
@extern fn mpd_qfinalize(result: mpd*, ctx: mpd_context*, status: mpd_status*);

@extern fn mpd_class(a: mpd*, ctx: mpd_context*) -> const char*;

@extern fn mpd_qcopy(result: mpd*, a: mpd*, status: mpd_status*) -> i32;
@extern fn mpd_qcopy_cxx(result: mpd*, a: mpd*) -> i32;
@extern fn mpd_qncopy(a: mpd*) -> mpd*;
@extern fn mpd_qcopy_abs(result: mpd*, a: mpd*, status: mpd_status*) -> i32;
