{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Sie",
    "scopeName": "source.sie",
    "patterns": [
        { "include": "#comments" },
        { "include": "#asm-block" },
        { "include": "#decorators" },
        { "include": "#imports" },
        { "include": "#function-declaration" },
        { "include": "#type-declaration" },
        { "include": "#keywords" },
        { "include": "#constants" },
        { "include": "#builtin-types" },
        { "include": "#builtin-names" },
        { "include": "#strings" },
        { "include": "#chars" },
        { "include": "#numbers" },
        { "include": "#enum-member" },
        { "include": "#function-call" },
        { "include": "#user-types" },
        { "include": "#self" },
        { "include": "#operators" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.sie",
                    "begin": "//",
                    "end": "$"
                },
                {
                    "name": "comment.block.sie",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "asm-block": {
            "begin": "(@)(asm)\\b",
            "beginCaptures": {
                "0": { "name": "storage.modifier.decorator.sie" }
            },
            "end": "(?<=\\})",
            "patterns": [
                { "include": "#comments" },
                {
                    "begin": "\\{",
                    "end": "\\}",
                    "contentName": "meta.embedded.block.asm.sie",
                    "patterns": [
                        {
                            "name": "comment.line.semicolon.asm.sie",
                            "match": ";.*$"
                        },
                        {
                            "name": "variable.other.interpolated.asm.sie",
                            "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
                        }
                    ]
                },
                { "include": "#strings" },
                { "include": "#keywords" },
                { "include": "#builtin-types" },
                {
                    "name": "storage.modifier.decorator.sie",
                    "match": "@[A-Za-z_][A-Za-z0-9_]*"
                }
            ]
        },
        "decorators": {
            "name": "storage.modifier.decorator.sie",
            "match": "@[A-Za-z_][A-Za-z0-9_]*"
        },
        "imports": {
            "patterns": [
                {
                    "match": "\\b(import)\\s+([A-Za-z_][A-Za-z0-9_.]*)(\\s+(as)\\s+([A-Za-z_][A-Za-z0-9_]*))?",
                    "captures": {
                        "1": { "name": "keyword.control.import.sie" },
                        "2": { "name": "entity.name.namespace.sie" },
                        "4": { "name": "keyword.control.import.sie" },
                        "5": { "name": "entity.name.namespace.sie" }
                    }
                },
                {
                    "match": "\\b(from)\\s+([A-Za-z_][A-Za-z0-9_.]*)",
                    "captures": {
                        "1": { "name": "keyword.control.import.sie" },
                        "2": { "name": "entity.name.namespace.sie" }
                    }
                },
                {
                    "name": "keyword.control.import.sie",
                    "match": "\\b(import|from)\\b"
                }
            ]
        },
        "function-declaration": {
            "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)(<[^>]*>)?(::)?([A-Za-z_][A-Za-z0-9_]*)?",
            "captures": {
                "1": { "name": "storage.type.function.sie" },
                "2": { "name": "entity.name.function.sie" },
                "3": { "name": "meta.generic.sie" },
                "4": { "name": "punctuation.accessor.sie" },
                "5": { "name": "entity.name.function.sie" }
            }
        },
        "type-declaration": {
            "match": "\\b(struct|union|enum|interface)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "storage.type.sie" },
                "2": { "name": "entity.name.type.sie" }
            }
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.sie",
                    "match": "\\b(if|else|while|for|foreach|case|when|break|continue|return|defer|emit)\\b"
                },
                {
                    "name": "keyword.operator.logical.sie",
                    "match": "\\b(and|or|not)\\b"
                },
                {
                    "name": "keyword.operator.expression.sie",
                    "match": "\\b(as|sizeof)\\b"
                },
                {
                    "name": "storage.type.sie",
                    "match": "\\b(fn|let|struct|union|enum|interface)\\b"
                },
                {
                    "name": "storage.modifier.sie",
                    "match": "\\b(const)\\b"
                }
            ]
        },
        "constants": {
            "name": "constant.language.sie",
            "match": "\\b(true|false|null)\\b"
        },
        "builtin-types": {
            "name": "support.type.primitive.sie",
            "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|char|raw)\\b"
        },
        "builtin-names": {
            "patterns": [
                {
                    "name": "support.class.builtin.sie",
                    "match": "\\b(Result|Iterator|Iterable|ArrayIterator|ConstArrayIterator|Enumerated|EnumerateIterator)\\b"
                },
                {
                    "name": "support.function.builtin.sie",
                    "match": "\\b(Ok|Error|enumerate)\\b(?=\\s*[(<])"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.sie",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.sie",
                    "match": "\\\\([abefnrtv\\\\'\"?]|[0-7]{1,3}|x[0-9a-fA-F]+)"
                }
            ]
        },
        "chars": {
            "name": "string.quoted.single.sie",
            "match": "'(\\\\([abefnrtv\\\\'\"?]|[0-7]{1,3}|x[0-9a-fA-F]+)|[^'\\\\])'",
            "captures": {
                "2": { "name": "constant.character.escape.sie" }
            }
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.sie",
                    "match": "\\b0x[0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.float.sie",
                    "match": "\\b[0-9]+\\.[0-9]+\\b"
                },
                {
                    "name": "constant.numeric.integer.sie",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "enum-member": {
            "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(::)([A-Za-z_][A-Za-z0-9_]*)\\b",
            "captures": {
                "1": { "name": "entity.name.type.sie" },
                "2": { "name": "punctuation.accessor.sie" },
                "3": { "name": "constant.other.enum.sie" }
            }
        },
        "function-call": {
            "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=\\()",
            "name": "entity.name.function.call.sie"
        },
        "user-types": {
            "name": "entity.name.type.sie",
            "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        "self": {
            "name": "variable.language.self.sie",
            "match": "\\bself\\b"
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.sie",
                    "match": "->"
                },
                {
                    "name": "keyword.operator.sie",
                    "match": "(\\*\\*=?|<<=?|>>=?|[-+*/%&|^]=?|==|!=|<=|>=|=|<|>|\\?|:|&|~)"
                }
            ]
        }
    }
}
